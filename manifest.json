{
  "manifest_version": 3,
  "name": "Cool New Tab",
  "version": "1.0.0",
  "description": "A beautiful, minimalist new tab with dynamic backgrounds, world clock, weather, quotes, calendar & news.",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": [
    "storage",
    "identity",
    "alarms"
  ],
  "host_permissions": [
    "https://api.unsplash.com/*",
    "https://api.openweathermap.org/*",
    "https://gnews.io/*",
    "https://www.googleapis.com/*"
  ],
  "oauth2": {
    "client_id": "410369913352-lfoc0e0jsttngsc971vj6etvg03opdnq.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/calendar.readonly"
    ]
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}